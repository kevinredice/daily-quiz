# Copy to .env.local and fill in.
# Public vars (Vite exposes anything prefixed VITE_ to the browser).
# These are safe to expose — Supabase anon key is meant for client-side use,
# protected by RLS.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...your-anon-key...

# If you leave these blank, the app runs in local-only mode (everything in
# localStorage, no sync, no Google sign-in).
